# Required for live Pisos API mode
PISOS_API_KEY=

# Optional: set to false to force missing-key errors instead of fixture fallback
PISOS_ALLOW_FIXTURE_FALLBACK=true

# Optional: set to true to use HTML scraping fallback when API is unavailable
PISOS_ENABLE_SCRAPE_FALLBACK=true

# Optional: milliseconds between scrape requests to avoid aggressive crawling
PISOS_SCRAPE_REQUEST_DELAY_MS=500

# Optional: upper bound on scrape requests per query execution
PISOS_MAX_SCRAPE_REQUESTS=6

# Optional API base override
PISOS_BASE_URL=https://api.pisos.com/v5

# Optional override for unknown upstream serialization details
# If provided, this value is used as the raw {busqueda} path segment.
# Example only; replace with a real serialized query from portal docs.
PISOS_SERIALIZED_SEARCH=

# Optional remote MCP endpoint for HTTP smoke checks
MCP_HTTP_URL=

# Optional hard timeout (ms) applied to all connector HTTP fetches
CONNECTOR_FETCH_TIMEOUT_MS=10000

# Optional: portal base overrides
TUCASA_BASE_URL=https://www.tucasa.com
FOTOCASA_BASE_URL=https://www.fotocasa.es
HABITACLIA_BASE_URL=https://www.habitaclia.com
YAENCONTRE_BASE_URL=https://www.yaencontre.com
MILANUNCIOS_BASE_URL=https://www.milanuncios.com
IDEALISTA_BASE_URL=https://www.idealista.com
GLOBALIZA_BASE_URL=https://www.globaliza.com
HOGARIA_BASE_URL=https://www.hogaria.net
SPAINHOUSES_BASE_URL=https://www.spainhouses.net
PISOCOMPARTIDO_BASE_URL=https://www.pisocompartido.com
ENALQUILER_BASE_URL=https://www.enalquiler.com
NUROA_BASE_URL=https://www.nuroa.es

# Optional: scraping pacing and bounds for non-key connectors
TUCASA_SCRAPE_REQUEST_DELAY_MS=250
TUCASA_MAX_SCRAPE_REQUESTS=6
FOTOCASA_SCRAPE_REQUEST_DELAY_MS=300
FOTOCASA_MAX_DETAIL_REQUESTS=8
HABITACLIA_SCRAPE_REQUEST_DELAY_MS=250
HABITACLIA_MAX_LISTINGS=20
HABITACLIA_MAX_SCRAPE_REQUESTS=6
YAENCONTRE_SCRAPE_REQUEST_DELAY_MS=350
YAENCONTRE_MAX_LISTINGS=20
YAENCONTRE_MAX_SCRAPE_REQUESTS=4
MILANUNCIOS_SCRAPE_REQUEST_DELAY_MS=300
MILANUNCIOS_MAX_LISTINGS=20
MILANUNCIOS_MAX_SCRAPE_REQUESTS=6
IDEALISTA_SCRAPE_REQUEST_DELAY_MS=350
IDEALISTA_MAX_LISTINGS=20
IDEALISTA_MAX_SCRAPE_REQUESTS=4
GLOBALIZA_SCRAPE_REQUEST_DELAY_MS=300
GLOBALIZA_MAX_LISTINGS=20
GLOBALIZA_MAX_SCRAPE_REQUESTS=6
HOGARIA_SCRAPE_REQUEST_DELAY_MS=300
HOGARIA_MAX_LISTINGS=20
HOGARIA_MAX_SCRAPE_REQUESTS=8
SPAINHOUSES_SCRAPE_REQUEST_DELAY_MS=300
SPAINHOUSES_MAX_LISTINGS=20
SPAINHOUSES_MAX_SCRAPE_REQUESTS=8
PISOCOMPARTIDO_SCRAPE_REQUEST_DELAY_MS=300
PISOCOMPARTIDO_MAX_LISTINGS=20
PISOCOMPARTIDO_MAX_SCRAPE_REQUESTS=6
ENALQUILER_SCRAPE_REQUEST_DELAY_MS=300
ENALQUILER_MAX_LISTINGS=20
ENALQUILER_MAX_SCRAPE_REQUESTS=8
NUROA_SCRAPE_REQUEST_DELAY_MS=300
NUROA_MAX_LISTINGS=20
NUROA_MAX_SCRAPE_REQUESTS=6
